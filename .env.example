# Copy to .env and fill in keys as the modules need them.
# .env is gitignored. Never commit secrets.

# Anthropic (Module 1+)
ANTHROPIC_API_KEY=

# OpenAI — embeddings + frontier comparison (Module 3+)
OPENAI_API_KEY=

# Cohere — hosted reranking baseline to A/B against local (Module 6)
COHERE_API_KEY=

# llama-swap — native llama.cpp server at C:\llm; the local runtime for
# roman-research. Serves chat (createLlamacpp, Qwen3.5-9B profiles), bge-m3
# embeddings (/v1/embeddings), and bge-reranker-v2-m3 reranking (/v1/rerank).
# Replaced LM Studio + the Infinity docker service (Module 6). Root URL, no /v1
# — the lib clients append the path. No API key needed.
LLAMA_SWAP_BASE_URL=http://127.0.0.1:8080

# Langfuse — tracing (wired up in Module 1)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Postgres + pgvector (Module 3+)
# Matches credentials in docker-compose.yml. `docker compose up -d` starts it.
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag_historian

# Local LLM runtime — which one createLocalLLM() picks. Default: lmstudio.
# LM Studio uses llama.cpp's GBNF grammar as a HARD constraint at the token
# sampler, so structured outputs are reliable across models. Ollama routes
# structured output through per-model renderers and engages GBNF inconsistently
# (Gemma 4 in particular leaks out-of-enum values). Override to ollama when
# you specifically want `ollama pull` ergonomics or a model only available there.
LOCAL_LLM_PROVIDER=lmstudio

# LM Studio — primary local. The wrapper appends `/v1` only if missing.
LM_STUDIO_BASE_URL=http://localhost:1234/v1
# Optional override of the default LM Studio model (otherwise uses LM_STUDIO_MODELS.gptOss20b)
LM_STUDIO_MODEL=

# Ollama — secondary local. The wrapper appends `/v1` automatically, so this
# can be either `http://localhost:11434` or `http://localhost:11434/v1`.
OLLAMA_BASE_URL=http://localhost:11434
# Optional override of the default Ollama model (otherwise uses OLLAMA_MODELS.gptOss20b)
OLLAMA_MODEL=
