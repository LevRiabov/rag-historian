# Copy to .env and fill in keys as the modules need them.
# .env is gitignored. Never commit secrets.

# Anthropic (Module 1+)
ANTHROPIC_API_KEY=

# OpenAI — embeddings + frontier comparison (Module 3+)
OPENAI_API_KEY=

# Cohere — reranking (Module 6)
COHERE_API_KEY=

# Langfuse — tracing (wired up in Module 1)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Postgres + pgvector (Module 3+)
DATABASE_URL=postgresql://localhost:5432/rag_historian

# LM Studio — primary local inference, OpenAI-compatible
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Ollama — secondary local (e.g., BGE-M3 embeddings in Module 3)
OLLAMA_BASE_URL=http://localhost:11434
